{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gate1-design-approved.sh",
            "shell": "bash",
            "statusMessage": "Gate 1: checking design approval...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gate2-delivery-approved.sh",
            "shell": "bash",
            "statusMessage": "Gate 2: checking delivery approval...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
