DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TIMEOUT=30
DEEPSEEK_MAX_RETRIES=3

# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
LLM_ENCRYPTION_KEY=generate-a-fernet-key
ADMIN_TOKEN=change-this-admin-token

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/xiaoshuo.log

# Database configuration
DATABASE_URL=postgresql+asyncpg://xiaoshuo:password@localhost:5432/xiaoshuo
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# 测试用数据库（pytest 自动探测；如需强制指定可在此设置）
# TEST_DATABASE_URL=postgresql+asyncpg://a1@localhost:5432/xiaoshuo_test

# 持久化生成任务队列
TASK_QUEUE_ENABLED=true
TASK_QUEUE_POLL_SECONDS=1.0
TASK_QUEUE_LEASE_SECONDS=120
TASK_QUEUE_RETRY_DELAY_SECONDS=5
